# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Database (must match docker-compose.yml) ---
POSTGRES_USER=biorag
POSTGRES_PASSWORD=biorag_dev_password
POSTGRES_DB=biorag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- LLM (API key) ---
NIM_API_KEY=
NIM_BASE_URL=
NIM_MODEL=

# --- Embeddings (local BiomedBERT — no API key needed, but specify model) ---
EMBEDDING_MODEL=

# --- Data paths ---
DATA_ROOT=

# --- App ---
APP_ENV=development
